# Seeker OS — Environment Variables (EXAMPLE)
# Copy to .env and fill in your API keys. .env is .gitignore'd.
#
# The settings UI (Models page) populates .env automatically when you save
# a provider key — you don't need to edit this file manually for LLM keys.
# An externally-injected env var (e.g. in Docker, CI, or your shell) is also
# honored at runtime; .env is just the local source of truth.

# ── LLM Provider API Keys ──
# Referenced by config/providers.yml as ${VAR_NAME}.
# The UI writes these automatically when you enter a key in the Models page.

# Anthropic direct API key (for Claude models via Anthropic's API)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Kilo Gateway API key (OpenAI-compatible gateway)
KILO_API_KEY=your-kilo-key-here

# ── LLM Observability ──
# HMAC key for privacy-safe prompt and claim fingerprints. Generate a long,
# random value for production; the raw prompts are never stored in telemetry.
SEEKER_TELEMETRY_HMAC_KEY=replace-with-a-long-random-value

# ── Company Research Retrieval ──
# Referenced by config/company_research.yml as ${RETRIEVAL_API_KEY}.
# Used by the Tavily retrieval adapter for live web search (funding + sentiment).
# Leave unset to disable retrieval (degrades cleanly to Wikipedia + Wikidata only).
RETRIEVAL_API_KEY=your-retrieval-key-here

# ── Docker Build Options ──
# Set INSTALL_BROWSER=false to skip Playwright/Chromium install during docker build.
# Use this on ARM64 hosts, machines without internet access during build, or if you
# don't need the Vercel JS-challenge browser fallback (httpx is the primary path).
# Default is true (attempts install, degrades gracefully if it fails).
# INSTALL_BROWSER=false

# ── Docker Port Mapping ──
# Host ports for compose.yaml. Change these if 3000/8000 are already in use.
# The container internals always listen on 3000/8000; these only remap the host side.
# Ports are bound to 127.0.0.1 only — not publicly exposed.
# A reverse proxy (nginx, Caddy, Traefik) on the host fronts these ports.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── CORS ──
# Comma-separated list of allowed origins for the frontend.
# For local dev (default): http://localhost:3000,http://127.0.0.1:3000
# For reverse proxy with a domain:
# CORS_ORIGINS=https://seeker-os.example.com
# CORS_ORIGINS=

# ── Frontend API URL (Docker) ──
# Browser-facing URL for the backend API. Only needed for Docker/production
# where the backend is on a non-default port or behind a reverse proxy.
# All API calls already have /api/ prefix, so the reverse proxy routes /api/* to backend.
# For reverse proxy with a domain:
# NEXT_PUBLIC_API_URL=https://seeker-os.example.com
# For non-default port without reverse proxy:
# NEXT_PUBLIC_API_URL=http://localhost:8800
