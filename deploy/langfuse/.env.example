# Langfuse — Environment Variables (EXAMPLE)
#
# Copy to .env and fill in the values. This file is for the Langfuse stack
# itself — separate from the main app's .env.
#
# Generate secrets with: openssl rand -base64 32

# NextAuth.js secret for JWT signing. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Salt for hashing API keys. Generate with:
#   openssl rand -base64 32
# Must be the same on every restart — don't regenerate after initial setup.
SALT=replace-with-openssl-rand-base64-32

# Encryption key for stored credentials (e.g. Langfuse Cloud integrations).
# Must be 64 hex characters (256 bits). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Host port for the Langfuse UI. Default 3001 to avoid conflict with the
# main stack's frontend (port 3000).
LANGFUSE_PORT=3001

# Postgres password for the Langfuse database.
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=replace-with-openssl-rand-base64-24

# Redis password. The compose file falls back to a well-known default if
# unset — always set your own. Generate with: openssl rand -base64 24
REDIS_AUTH=replace-with-openssl-rand-base64-24

# ClickHouse credentials.
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=replace-with-openssl-rand-base64-24

# MinIO credentials for S3-compatible blob storage.
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-with-openssl-rand-base64-24
